---
interface ComponentProps {
	name: string;
	type: string;
	default?: string;
	description: string;
}

interface Props {
	id?: string;
	name: string;
	serial: string;
	propDefinitions: Array<ComponentProps>;
}

const { id, name, serial, propDefinitions } = Astro.props;
---

<section id={id} class='px-6 md:px-10 py-12 border-b border-line'>
	<div class='flex items-baseline justify-between mb-8'>
		<h2 class='font-display font-black text-3xl tracking-widest text-off-white'>{name}</h2>
		<span class='serial'>{serial}</span>
	</div>

	<div class='border border-line p-6 mb-8 bg-surface'>
		<slot />
	</div>

	{
		propDefinitions.length > 0 && (
			<table class='w-full border border-line text-left'>
				<thead class='border-b border-line bg-black'>
					<tr>
						<th class='px-4 py-3 font-mono text-xs text-dim tracking-widest uppercase'>Prop</th>
						<th class='px-4 py-3 font-mono text-xs text-dim tracking-widest uppercase'>Type</th>
						<th class='px-4 py-3 font-mono text-xs text-dim tracking-widest uppercase'>Default</th>
						<th class='px-4 py-3 font-mono text-xs text-dim tracking-widest uppercase'>Description</th>
					</tr>
				</thead>
				<tbody>
					{propDefinitions.map((prop) => (
						<tr class='border-b border-line'>
							<td class='px-4 py-3 font-mono text-xs text-orange normal-case'>{prop.name}</td>
							<td class='px-4 py-3 font-mono text-xs text-dim normal-case'>{prop.type}</td>
							<td class='px-4 py-3 font-mono text-xs text-dim normal-case'>{prop.default ?? "-"}</td>
							<td class='px-4 py-3 text-xs text-dim normal-case tracking-wider'>{prop.description}</td>
						</tr>
					))}
				</tbody>
			</table>
		)
	}
</section>

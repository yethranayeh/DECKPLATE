---
interface FontFamily {
	name: string;
	role: string;
	source: string;
	import: string;
	weights: number[];
	fallback: string;
	rules: string[];
}

interface Props {
	font: FontFamily;
}

const { font } = Astro.props;
---

<div class='border border-line flex flex-col'>
	<div class='p-10 bg-surface border-b border-line flex items-end min-h-35'>
		<span
			class='text-off-white font-black leading-none'
			style={`font-family: ${font.name}, ${font.fallback}; font-size: clamp(2.5rem, 6vw, 4rem);`}>
			{font.name.split(" ")[0].toUpperCase()}
		</span>
	</div>

	<div class='p-6 flex flex-col gap-5'>
		<div class='flex flex-col gap-1.5'>
			<div class='text-xl font-black leading-tight'>{font.name.toUpperCase()}</div>
			<div class='text-[10px] tracking-widest leading-normal text-orange'>{font.role.toUpperCase()}</div>
		</div>

		<div class='grid grid-cols-2 gap-3 pt-4 border-t border-line'>
			<div class='flex flex-col gap-1.5'>
				<span class='font-mono text-xs tracking-widest leading-normal text-orange'>SOURCE</span>
				<span class='text-[0.65rem] tracking-[0.08em] leading-normal text-dim normal-case font-normal'>
					{font.source}
				</span>
			</div>
			<div class='flex flex-col gap-1.5'>
				<span class='font-mono text-[10px] tracking-widest leading-normal text-orange'>FALLBACK</span>
				<span class='text-[0.65rem] tracking-[0.08em] leading-normal text-dim normal-case font-normal'>
					{font.fallback}
				</span>
			</div>
		</div>

		<div class='flex gap-2 flex-wrap pt-4 border-t border-line'>
			<!-- TODO: Replace with Badge component -->
			{
				font.weights.map((w) => (
					<span
						class='px-2.5 py-1 border border-line text-[10px] tracking-widest leading-normal text-dim'
						style={`font-weight:${w};`}>
						{w}
					</span>
				))
			}
		</div>

		<div class='pt-4 border-t border-line flex flex-col gap-1.5'>
			{
				font.rules.map((r) => (
					<div class='text-sm tracking-normal leading-relaxed text-dim normal-case font-normal py-0.5 flex gap-2'>
						<span class='text-orange shrink-0'>&middot;</span>
						{r}
					</div>
				))
			}
		</div>

		<div class='pt-4 border-t border-line flex flex-col gap-1.5'>
			<span class='font-mono text-xs tracking-widest leading-normal text-orange'>IMPORT</span>
			<code class='text-[10px] tracking-tight leading-normal text-dim normal-case font-normal break-all'>
				{font.import}
			</code>
		</div>
	</div>
</div>

---
import tokens from "../../data/tokens.json";
import SectionLayout from "../../layouts/SectionLayout.astro";

const { palette } = tokens;

const roleBorderColor: Record<string, string> = {
	primary: "border-orange text-orange",
	background: "border-off-white/30 text-off-white/60",
	warning: "border-yellow text-yellow",
	danger: "border-red text-red",
	"danger-highlight": "border-red-hi text-red-hi",
	foreground: "border-off-white/50 text-off-white/70",
	surface: "border-off-white/20 text-off-white/50",
	border: "border-off-white/20 text-off-white/50",
	muted: "border-dim text-dim"
};
---

<SectionLayout title='Palette' description='All Tokens'>
	<div class='grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6'>
		{
			palette.map((c) => (
				<div class='border border-line flex flex-col overflow-hidden'>
					<div class='relative h-24' style={`background:${c.hex};`} />

					<div class='p-5 flex flex-col gap-4 flex-1'>
						<div class='flex justify-between items-start gap-4'>
							<span class='text-xl font-black leading-tight'>{c.name.toUpperCase()}</span>
							<div class='flex flex-col items-end'>
								<span class='font-mono text-sm tracking-normal leading-normal text-orange'>{c.hex}</span>
								<span class='font-display text-[10px] tracking-wider leading-normal text-dim normal-case'>
									rgb({c.rgb.join(", ")})
								</span>
							</div>
						</div>

						<div class='flex items-center justify-between gap-3'>
							<span class='font-mono text-[10px] text-dim tracking-widest leading-normal normal-case'>
								<code class='text-off-white/70'>{c.token}</code>
							</span>

							{/* TODO: replace with a Badge component */}
							<span
								class:list={[
									"font-mono text-[10px] tracking-widest leading-normal uppercase px-2.5 py-1 border shrink-0",
									roleBorderColor[c.role] ?? "border-line text-dim"
								]}>
								{c.role.toUpperCase()}
							</span>
						</div>

						<p class='text-sm leading-snug text-off-white normal-case font-normal'>{c.usage}</p>

						<div class='grid grid-cols-2 gap-3 pt-4 border-t border-line'>
							<div class='flex flex-col'>
								<span class='font-mono text-xs leading-normal text-orange'>ON TOP OF</span>
								<span class='text-[10px] leading-normal text-dim normal-case font-normal'>{c.onLabel}</span>
							</div>
							<div class='flex flex-col'>
								<span class='font-mono text-xs leading-normal text-orange'>PAIRS WITH</span>
								<span class='text-[10px] leading-normal text-dim normal-case font-normal'>{c.pairing.join(", ")}</span>
							</div>
						</div>

						{/* TODO: Replace with an Alert componen */}
						<div class='text-xs tracking-wider leading-relaxed text-red-hi font-normal pl-3 py-2.5 border-l border-red-hi bg-red-hi/5 flex flex-col'>
							<span>// Avoid</span>
							<span class='normal-case'>{c.avoid}</span>
						</div>
					</div>
				</div>
			))
		}
	</div>
</SectionLayout>

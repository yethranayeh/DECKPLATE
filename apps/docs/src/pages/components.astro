---
import Layout from "../layouts/Layout.astro";
import ComponentLayout from "../layouts/ComponentLayout.astro";

import PageHeader from "../components/PageHeader.astro";

import { ButtonDemo } from "../features/components/ButtonDemo";
import { BadgeDemo } from "../features/components/BadgeDemo";
import { StatusDotDemo } from "../features/components/StatusDotDemo";
import { ProgressBarDemo } from "../features/components/ProgressBarDemo";
import { TypographyDemo } from "../features/components/TypographyDemo";

import { ABBR } from "../data/constants";
---

<Layout title='Components' serial={`DOC# ${ABBR}-2026-003`}>
	<PageHeader title='Components' tagline='Operational UI Primitives' serial='03 // COMPONENT REGISTRY' />

	<ComponentLayout
		name='Button'
		serial='CMP-001'
		usage={`import { Button } from "@/ui/button"

<Button variant="primary">Deploy</Button>
<Button variant="danger" size="lg">Terminate</Button>
<Button variant="outline" disabled>Locked</Button>`}
		propDefinitions={[
			{
				name: "variant",
				type: "'primary' | 'danger' | 'outline' | 'ghost'",
				default: "'primary'",
				description: "Visual style of the button"
			},

			{
				name: "size",
				type: "'sm' | 'md' | 'lg'",
				default: "'md'",
				description: "Size of the button"
			},
			{
				name: "disabled",
				type: "boolean",
				default: "false",
				description: "Disables the button"
			},
			{
				name: "className",
				type: "string",
				description: "Additional arbitrary classes"
			}
		]}>
		<ButtonDemo client:load />
	</ComponentLayout>

	<ComponentLayout
		name='Badge'
		serial='CMP-002'
		usage={`import { Badge } from "@/ui/badge"

<Badge>Default</Badge>
<Badge variant="fill-orange" dot>Active</Badge>
<Badge variant="outline-red">Critical</Badge>`}
		propDefinitions={[
			{
				name: "variant",
				type: "'outline-orange' | 'outline-red' | 'outline-yellow' | 'outline-white' | 'fill-orange' | 'fill-red' | 'fill-yellow'",
				default: "'outline-orange'",
				description: "Visual style of the badge"
			},
			{
				name: "dot",
				type: "boolean",
				default: "false",
				description: "Shows a small status dot before the label"
			},
			{
				name: "className",
				type: "string",
				description: "Additional arbitrary classes"
			}
		]}>
		<BadgeDemo client:load />
	</ComponentLayout>

	<ComponentLayout
		name='Status Dot'
		serial='CMP-003'
		usage={`import { StatusDot } from "@/ui/status-dot"

<StatusDot aria-label="System status" variant="active" />
<StatusDot aria-label="Warning" variant="warning" pulse />
<StatusDot aria-label="Offline" variant="offline" size="lg" />`}
		propDefinitions={[
			{
				name: "aria-label",
				type: "string",
				description: "Required prop to make it accessible for screen readers"
			},
			{
				name: "variant",
				type: "'active' | 'warning' | 'danger' | 'offline'",
				default: "'offline'",
				description: "Current status state"
			},
			{
				name: "size",
				type: "'sm' | 'md' | 'lg'",
				default: "'md'",
				description: "Size of the dot"
			},
			{
				name: "pulse",
				type: "boolean",
				default: "false",
				description: "Enables pulse animations. When enabled, disables glow."
			},
			{
				name: "disableGlow",
				type: "boolean",
				default: "false",
				description: "Disables the glow shadow"
			},
			{
				name: "className",
				type: "string",
				description: "Additional arbitrary classes"
			}
		]}>
		<StatusDotDemo client:load />
	</ComponentLayout>

	<ComponentLayout
		name='Progress Bar'
		serial='CMP-004'
		usage={`import { ProgressBar } from "@/ui/progress-bar"

<ProgressBar value={72} label="Upload" />
<ProgressBar value={15} threshold={30} />
<ProgressBar value={100} hideValue />`}
		propDefinitions={[
			{
				name: "value",
				type: "number",
				default: "0",
				description: "Progress value (0-100)"
			},
			{
				name: "threshold",
				type: "number",
				default: "30",
				description: "When `value <= threshold`, then the color turns red"
			},
			{
				name: "hideValue",
				type: "boolean",
				default: "false",
				description: "Optional prop to hide percentage value"
			},
			{
				name: "label",
				type: "string",
				description: "Optional label text shown on top left of the bar"
			},
			{
				name: "className",
				type: "string",
				description: "Additional arbitrary classes"
			}
		]}>
		<ProgressBarDemo client:load />
	</ComponentLayout>

	<ComponentLayout
		id='typography'
		name='Typography'
		serial='CMP-005'
		usage={`import { Typography } from "@/ui/typography"

<Typography variant="display">Signal Nominal</Typography>
<Typography variant="headline-xl">Macro-Telemetry Refinement</Typography>
<Typography variant="headline-lg">Structural Integrity</Typography>
<Typography variant="label-md">Operator Clearance Required</Typography>
<Typography variant="label-sm">Unit SPOT-100 // Archival Processing // Rev 4.2</Typography>
<Typography variant="serial">MTR-400263-250 // b11205d698e</Typography>`}
		propDefinitions={[
			{
				name: "variant",
				type: "'display' | 'headline-xl' | 'headline-lg' | 'label-md' | 'label-sm' | 'serial'",
				default: "'label-md'",
				description: "Typography preset"
			},
			{
				name: "as",
				type: "React.ElementType",
				description: "Override the rendered HTML element (defaults: h1, h2, h3, p, p, span)"
			},
			{
				name: "className",
				type: "string",
				description: "Additional arbitrary classes"
			}
		]}>
		<TypographyDemo client:load />
	</ComponentLayout>
</Layout>
